---
import { Icon } from "astro-icon/components";
import { hotspotsByMode, hotspotMedia, type HotspotMode } from "../data/hotspots";
import { mediaById } from "../data/media";
import MediaFrame from "./MediaFrame.astro";

const modes: { id: HotspotMode; label: string; hint: string }[] = [
  { id: "exterior", label: "Dış görünüş", hint: "Gövde ve donanım" },
  { id: "interior", label: "İç mekân", hint: "Kokpit ve kumandalar" },
  { id: "tires", label: "Lastikler", hint: "Jant, DOT ve durum" },
];
const initialHotspot = hotspotsByMode.exterior[0]!;
---

<section class="atlas chapter chapter--large" id="arac-atlasi" aria-labelledby="atlas-title" data-atlas>
  <div class="page-shell">
    <div class="chapter__heading atlas__heading">
      <p class="eyebrow">Etkileşimli araç atlası</p>
      <h2 id="atlas-title">Fotoğrafın üzerinde, bilgiye dokun.</h2>
      <p>Beyaz yörünge noktaları fotoğrafta doğrulanabilen parçaları ve satıcı notlarını açar.</p>
    </div>

    <div class="atlas__tabs" role="tablist" aria-label="Araç atlası görünümü">
      {modes.map((mode, index) => (
        <button
          class="atlas__tab"
          type="button"
          role="tab"
          id={`atlas-tab-${mode.id}`}
          aria-controls={`atlas-panel-${mode.id}`}
          aria-selected={index === 0 ? "true" : "false"}
          tabindex={index === 0 ? 0 : -1}
          data-atlas-tab={mode.id}
        >
          <span>{mode.label}</span>
          <small>{mode.hint}</small>
        </button>
      ))}
    </div>

    <div class="atlas__workspace technical-panel">
      <div class="atlas__stage">
        {modes.map((mode, index) => {
          const asset = mediaById[hotspotMedia[mode.id]]!;
          return (
            <div
              class="atlas__view"
              id={`atlas-panel-${mode.id}`}
              role="tabpanel"
              aria-labelledby={`atlas-tab-${mode.id}`}
              hidden={index !== 0}
              data-atlas-panel={mode.id}
            >
              <MediaFrame asset={asset} widths={[480, 768, 1100, 1440]} sizes="(max-width: 900px) 100vw, 72vw" />
              <div class="atlas__points" aria-label={`${mode.label} bilgi noktaları`}>
                {hotspotsByMode[mode.id].map((hotspot, hotspotIndex) => (
                  <button
                    class="hotspot"
                    class:list={{ "hotspot--active": index === 0 && hotspotIndex === 0 }}
                    type="button"
                    style={`--hotspot-x:${hotspot.x}%;--hotspot-y:${hotspot.y}%`}
                    aria-label={`${hotspot.title} bilgisini aç`}
                    aria-expanded={index === 0 && hotspotIndex === 0 ? "true" : "false"}
                    aria-controls="atlas-detail"
                    data-hotspot-id={hotspot.id}
                    data-hotspot={JSON.stringify(hotspot)}
                  >
                    <span aria-hidden="true"></span>
                  </button>
                ))}
              </div>
            </div>
          );
        })}
      </div>

      <aside class="atlas__detail" id="atlas-detail" aria-live="polite" data-atlas-detail>
        <p class="atlas__index technical">NOKTA <span data-detail-index>01</span></p>
        <div>
          <h3 data-detail-title>{initialHotspot.title}</h3>
          <p class="atlas__summary" data-detail-summary>{initialHotspot.summary}</p>
          <p data-detail-text>{initialHotspot.detail}</p>
        </div>
        <ul class="source-tags" data-detail-sources>
          {initialHotspot.sources.map((source) => (
            <li class="source-tag">{source === "fotograf" ? "Fotoğraf" : "Satıcı beyanı"}</li>
          ))}
        </ul>
        <span class="atlas__mode technical" data-detail-mode>Dış görünüş</span>
      </aside>
    </div>
  </div>

  <dialog class="atlas-sheet" aria-labelledby="atlas-sheet-title" data-atlas-sheet>
    <div class="atlas-sheet__handle" aria-hidden="true"></div>
    <div class="atlas-sheet__head">
      <span class="technical" data-sheet-mode>Dış görünüş</span>
      <button type="button" aria-label="Bilgi panelini kapat" data-atlas-close>
        <Icon name="ph:x" aria-hidden="true" />
      </button>
    </div>
    <div class="atlas-sheet__body">
      <h3 id="atlas-sheet-title" data-sheet-title>{initialHotspot.title}</h3>
      <p class="atlas__summary" data-sheet-summary>{initialHotspot.summary}</p>
      <p data-sheet-text>{initialHotspot.detail}</p>
      <ul class="source-tags" data-sheet-sources></ul>
    </div>
  </dialog>
</section>

<script src="../scripts/atlas.ts"></script>

<style>
  .atlas {
    border-block: 1px solid var(--border-default);
    background: var(--surface-void);
  }

  .atlas__heading {
    grid-template-columns: minmax(0, 1fr) minmax(280px, 0.6fr);
    align-items: end;
  }

  .atlas__heading .eyebrow,
  .atlas__heading h2 {
    grid-column: 1;
  }

  .atlas__heading > p:last-child {
    grid-column: 2;
    grid-row: 1 / span 2;
  }

  .atlas__tabs {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    border: 1px solid var(--border-default);
    border-bottom: 0;
  }

  .atlas__tab {
    min-height: 68px;
    display: grid;
    gap: var(--space-1);
    align-content: center;
    padding: var(--space-3) var(--space-5);
    border-right: 1px solid var(--border-default);
    background: var(--surface-primary);
    color: var(--text-secondary);
    cursor: pointer;
    text-align: left;
    transition: background-color 240ms ease-in-out, color 240ms ease-in-out;
  }

  .atlas__tab:last-child { border-right: 0; }

  .atlas__tab[aria-selected="true"] {
    background: var(--surface-elevated);
    color: var(--text-primary);
    box-shadow: inset 0 2px 0 var(--accent-primary);
  }

  .atlas__tab small {
    color: var(--text-tertiary);
    font-family: var(--font-technical);
    font-size: var(--type-micro);
  }

  .atlas__workspace {
    display: grid;
    grid-template-columns: minmax(0, 3fr) minmax(280px, 1fr);
  }

  .atlas__stage {
    min-width: 0;
    border-right: 1px solid var(--border-default);
  }

  .atlas__view {
    position: relative;
    aspect-ratio: 4 / 3;
    background: var(--surface-primary);
  }

  .atlas__view[hidden] { display: none; }

  .atlas__view :global(.media-frame) {
    height: 100%;
    border-radius: 0;
  }

  .atlas__view :global(.media-frame img) { object-fit: contain; object-position: center; }

  .atlas__points { position: absolute; inset: 0; }

  .hotspot {
    position: absolute;
    left: var(--hotspot-x);
    top: var(--hotspot-y);
    width: 48px;
    height: 48px;
    display: grid;
    place-items: center;
    border-radius: var(--radius-circle);
    background: transparent;
    cursor: pointer;
    transform: translate(-50%, -50%);
  }

  .hotspot::before,
  .hotspot span {
    position: absolute;
    border-radius: var(--radius-circle);
    content: "";
  }

  .hotspot::before {
    inset: 7px;
    border: 1px solid var(--text-primary);
    background: var(--overlay-soft);
    opacity: 0.8;
    transition: transform 240ms var(--ease-standard), opacity 240ms ease-in-out;
  }

  .hotspot span {
    width: 8px;
    height: 8px;
    background: var(--text-primary);
  }

  .hotspot:hover::before,
  .hotspot:focus-visible::before,
  .hotspot--active::before {
    border-color: var(--accent-soft);
    transform: scale(1.28);
    opacity: 1;
  }

  .hotspot--active span { background: var(--accent-primary); }

  .atlas__detail {
    min-height: 620px;
    display: flex;
    flex-direction: column;
    gap: var(--space-8);
    padding: var(--space-8);
    background: var(--surface-secondary);
  }

  .atlas__index,
  .atlas__mode {
    color: var(--text-tertiary);
    font-size: var(--type-micro);
    letter-spacing: 0.08em;
  }

  .atlas__detail > div { display: grid; gap: var(--space-4); }

  .atlas__detail h3,
  .atlas-sheet h3 {
    font-size: var(--type-h3);
    font-weight: 540;
    line-height: 1.25;
  }

  .atlas__detail p:not(.atlas__summary),
  .atlas-sheet__body > p:not(.atlas__summary) {
    color: var(--text-secondary);
    font-size: var(--type-body-sm);
  }

  .atlas__summary { color: var(--text-primary); }
  .atlas__mode { margin-top: auto; }

  .atlas-sheet { width: 100%; }
  .atlas-sheet__handle {
    width: 44px;
    height: 4px;
    margin: var(--space-3) auto 0;
    border-radius: var(--radius-control);
    background: var(--border-strong);
  }
  .atlas-sheet__head {
    min-height: 52px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: var(--space-3) var(--space-4);
    border-bottom: 1px solid var(--border-default);
    color: var(--text-tertiary);
    font-size: var(--type-caption);
  }
  .atlas-sheet__head button {
    width: 44px;
    height: 44px;
    border-radius: var(--radius-circle);
    background: var(--surface-secondary);
    cursor: pointer;
    font-size: 1.25rem;
  }
  .atlas-sheet__body { display: grid; gap: var(--space-4); padding: var(--space-6); }

  @media (max-width: 900px) {
    .atlas__workspace { grid-template-columns: 1fr; }
    .atlas__stage { border-right: 0; }
    .atlas__detail { display: none; }
  }

  @media (max-width: 767px) {
    .atlas__heading { grid-template-columns: 1fr; }
    .atlas__heading > p:last-child { grid-column: 1; grid-row: auto; }
    .atlas__tabs { grid-template-columns: 1fr; border-bottom: 1px solid var(--border-default); }
    .atlas__tab { min-height: 58px; border-right: 0; border-bottom: 1px solid var(--border-default); }
    .atlas__tab:last-child { border-bottom: 0; }
    .atlas__tab small { display: none; }
    .atlas__workspace { border-top: 0; }
    .atlas-sheet { max-width: 100vw; margin: auto 0 0; border-radius: var(--radius-media) var(--radius-media) 0 0; }
  }
</style>
