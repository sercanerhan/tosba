---
import { Picture, getImage } from "astro:assets";
import { Icon } from "astro-icon/components";
import { galleryAssets } from "../data/media";

const filters = [
  { id: "today", label: "Bugünkü hâli" },
  { id: "interior", label: "Kabin" },
  { id: "evidence", label: "Hasar / onarım" },
  { id: "archive", label: "Arşiv" },
];

const items = await Promise.all(galleryAssets.map(async (asset) => {
  const large = await getImage({ src: asset.src, width: Math.min(asset.src.width, 1600), format: "webp", quality: 82 });
  const filter = asset.category === "damage" || asset.category === "repair" ? "evidence" : asset.category;
  return { asset, large, filter };
}));
---

<section class="gallery chapter chapter--large" id="galeri" aria-labelledby="gallery-title" data-gallery>
  <div class="page-shell">
    <div class="chapter__heading gallery__heading">
      <p class="eyebrow">Görsel kayıt</p>
      <h2 id="gallery-title">Bugün, kabin, kanıt ve arşiv.</h2>
      <p>Fotoğraflar yeniden işlenmiş web türevleridir. Kişisel veriler gizlenir; arşiv varsayılan olarak kapalıdır.</p>
    </div>

    <div class="gallery__filters" role="group" aria-label="Galeri filtreleri">
      {filters.map((filter, index) => (
        <button
          class="gallery__filter"
          type="button"
          aria-pressed={index === 0 ? "true" : "false"}
          data-gallery-filter={filter.id}
        >{filter.label}</button>
      ))}
    </div>

    <div class="gallery__grid" data-gallery-grid>
      {items.map(({ asset, large, filter }) => (
        <article
          class="gallery-card"
          class:list={{ "gallery-card--archive": filter === "archive" }}
          data-gallery-item={filter}
          hidden={filter !== "today"}
        >
          <a
            href={large.src}
            class="gallery-card__link"
            data-pswp-width={large.attributes.width}
            data-pswp-height={large.attributes.height}
            data-cropped="true"
            aria-label={`${asset.caption} fotoğrafını büyüt`}
          >
            <Picture
              src={asset.src}
              formats={["avif"]}
              fallbackFormat="webp"
              widths={[360, 720, 960]}
              sizes="(max-width: 767px) 100vw, (max-width: 1100px) 50vw, 34vw"
              alt={asset.alt}
              loading="lazy"
              decoding="async"
            />
            {asset.privacyMasks?.map((mask) => (
              <span
                class="gallery-card__mask"
                style={`--mask-left:${mask.left}%;--mask-top:${mask.top}%;--mask-width:${mask.width}%;--mask-height:${mask.height}%`}
                aria-hidden="true"
              ></span>
            ))}
            <span class="gallery-card__open"><Icon name="ph:arrows-out" aria-hidden="true" /></span>
          </a>
          <div class="gallery-card__caption">
            <span>{asset.caption}</span>
            <small class="technical">{asset.source}</small>
          </div>
        </article>
      ))}
    </div>

    <p class="gallery__privacy"><Icon name="ph:shield-check" aria-hidden="true" /> Orijinaller korunur; web çıktılarında EXIF/GPS verisi taşınmaz.</p>
  </div>
</section>

<script src="../scripts/gallery.ts"></script>

<style>
  .gallery { background: var(--surface-void); }
  .gallery__heading { grid-template-columns: minmax(0, 1fr) minmax(280px, .7fr); align-items: end; }
  .gallery__heading .eyebrow,
  .gallery__heading h2 { grid-column: 1; }
  .gallery__heading > p:last-child { grid-column: 2; grid-row: 1 / span 2; }
  .gallery__filters { display: flex; flex-wrap: wrap; gap: var(--space-2); margin-bottom: var(--space-8); }
  .gallery__filter { min-height: 44px; padding: var(--space-2) var(--space-4); border: 1px solid var(--border-default); border-radius: var(--radius-control); background: transparent; color: var(--text-secondary); cursor: pointer; font-size: var(--type-body-sm); }
  .gallery__filter[aria-pressed="true"] { border-color: var(--accent-primary); background: var(--surface-secondary); color: var(--text-primary); }
  .gallery__grid { display: grid; grid-template-columns: repeat(12, 1fr); gap: var(--space-4); }
  .gallery-card { grid-column: span 4; min-width: 0; border: 1px solid var(--border-default); background: var(--surface-primary); }
  .gallery-card:nth-child(5n + 1) { grid-column: span 7; }
  .gallery-card:nth-child(5n + 2) { grid-column: span 5; }
  .gallery-card[hidden] { display: none; }
  .gallery-card__link { position: relative; height: clamp(280px, 36vw, 520px); display: block; overflow: hidden; }
  .gallery-card__link :global(picture),
  .gallery-card__link :global(img) { width: 100%; height: 100%; }
  .gallery-card__link :global(img) { object-fit: cover; transition: transform 600ms var(--ease-standard), filter 240ms ease-in-out; }
  .gallery-card__link:hover :global(img),
  .gallery-card__link:focus-visible :global(img) { transform: scale(1.025); filter: brightness(.86); }
  .gallery-card__mask { position: absolute; left: var(--mask-left); top: var(--mask-top); width: var(--mask-width); height: var(--mask-height); border: 1px solid var(--border-default); border-radius: var(--radius-control); background: var(--surface-void); opacity: 1; }
  .gallery-card__open { position: absolute; right: var(--space-3); top: var(--space-3); width: 44px; height: 44px; display: grid; place-items: center; border: 1px solid var(--border-default); border-radius: var(--radius-circle); background: var(--overlay-scrim); }
  .gallery-card__caption { min-height: 66px; display: flex; align-items: center; justify-content: space-between; gap: var(--space-4); padding: var(--space-3) var(--space-4); }
  .gallery-card__caption span { font-size: var(--type-body-sm); }
  .gallery-card__caption small { color: var(--text-tertiary); font-size: var(--type-micro); text-align: right; }
  .gallery__privacy { display: flex; gap: var(--space-2); align-items: center; margin-top: var(--space-6); color: var(--text-tertiary); font-size: var(--type-caption); }
  .gallery__privacy :global(svg) { flex: 0 0 auto; width: 1rem; height: 1rem; color: var(--status-success); }
  @media (max-width: 900px) {
    .gallery-card,
    .gallery-card:nth-child(5n + 1),
    .gallery-card:nth-child(5n + 2) { grid-column: span 6; }
  }
  @media (max-width: 767px) {
    .gallery__heading { grid-template-columns: 1fr; }
    .gallery__heading > p:last-child { grid-column: 1; grid-row: auto; }
    .gallery__filters { flex-wrap: nowrap; overflow-x: auto; padding-bottom: var(--space-2); }
    .gallery__filter { flex: 0 0 auto; }
    .gallery-card,
    .gallery-card:nth-child(5n + 1),
    .gallery-card:nth-child(5n + 2) { grid-column: span 12; }
    .gallery-card__link { height: min(72vw, 420px); }
  }
</style>
