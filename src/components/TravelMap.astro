---
import { Picture } from "astro:assets";
import type { EvidenceSource } from "../lib/listing-schema";
import { mediaById } from "../data/media";
import {
  projectTravelStop,
  travelRegionOrder,
  travelStops,
  turkeyOutlinePath,
} from "../data/travel-stops";
import SourceTags from "./SourceTags.astro";

type Props = { years: number };
const { years } = Astro.props;
const texture = mediaById["atlas-texture"]!;
const sources: EvidenceSource[] = ["satici_beyani"];
const projectedStops = travelStops.map((stop) => ({ ...stop, ...projectTravelStop(stop) }));
const stopsByRegion = travelRegionOrder.map((region) => ({
  region,
  stops: projectedStops.filter((stop) => stop.region === region),
}));
const initialStop = projectedStops[0]!;
---

<section class="travel-map chapter chapter--large" id="yolculuk" aria-labelledby="travel-map-title" data-travel-map>
  <div class="content-shell">
    <div class="chapter__heading travel-map__heading">
      <p class="eyebrow">Yolculuk atlası</p>
      <h2 id="travel-map-title">14 yılda, Türkiye yollarında.</h2>
      <div class="travel-map__intro">
        <p>Marmara’dan Karadeniz’e, Ege’den Akdeniz’e; bu araç {travelStops.length} farklı durağı ziyaret etti.</p>
        <SourceTags sources={sources} />
      </div>
    </div>

    <div class="travel-map__workspace technical-panel">
      <div class="travel-map__stage">
        <div class="travel-map__ambient" aria-hidden="true">
          <Picture
            src={texture.src}
            formats={["avif"]}
            fallbackFormat="webp"
            widths={[768, 1180]}
            sizes="(max-width: 900px) 100vw, 72vw"
            alt=""
            loading="lazy"
            decoding="async"
          />
        </div>

        <div class="travel-map__visual">
          <svg
            viewBox="0 0 1000 460"
            role="img"
            aria-labelledby="travel-map-visual-title travel-map-visual-description"
            preserveAspectRatio="xMidYMid meet"
          >
            <title id="travel-map-visual-title">Türkiye’de ziyaret edilen yerler</title>
            <desc id="travel-map-visual-description">Aracın {years} yılda ziyaret ettiği on beş yerin Türkiye üzerindeki konumları.</desc>
            <path d={turkeyOutlinePath} fill-rule="evenodd"></path>
          </svg>

          <div class="travel-map__markers" aria-hidden="true">
            {projectedStops.map((stop, index) => {
              const [labelX = 0, labelY = -16] = stop.labelOffset ?? [];
              return (
                <span
                  class="travel-map__marker"
                  data-travel-marker={stop.id}
                  data-active={index === 0 ? "true" : "false"}
                  style={`--marker-x:${stop.x}%;--marker-y:${stop.y}%;--label-x:${labelX}px;--label-y:${labelY}px`}
                >
                  <span class="travel-map__marker-ring"></span>
                  <span class="travel-map__marker-dot"></span>
                  <span class="travel-map__marker-label">{stop.name}</span>
                </span>
              );
            })}
          </div>
        </div>

        <p class="travel-map__readout" id="travel-map-active" aria-live="polite" aria-atomic="true">
          <span class="technical" data-travel-active-region>{initialStop.region}</span>
          <strong data-travel-active-name>{initialStop.name}</strong>
        </p>
      </div>

      <aside class="travel-map__index" aria-label="Ziyaret edilen yerler">
        <div class="travel-map__index-head">
          <p class="technical">{travelStops.length} DURAK · {travelRegionOrder.length} BÖLGE</p>
          <p>Bir konumu seçerek haritadaki yerini öne çıkarın.</p>
        </div>

        <div class="travel-map__regions">
          {stopsByRegion.map(({ region, stops }) => (
            <section class="travel-map__region" aria-labelledby={`travel-region-${region.replaceAll(" ", "-").toLocaleLowerCase("tr")}`}>
              <h3 id={`travel-region-${region.replaceAll(" ", "-").toLocaleLowerCase("tr")}`} class="technical">{region}</h3>
              <div class="travel-map__places" role="group" aria-label={`${region} durakları`}>
                {stops.map((stop) => (
                  <button
                    class="travel-map__place"
                    type="button"
                    aria-pressed={stop.id === initialStop.id ? "true" : "false"}
                    aria-controls="travel-map-active"
                    data-travel-control={stop.id}
                    data-travel-name={stop.name}
                    data-travel-region={stop.region}
                  >
                    <span aria-hidden="true"></span>
                    {stop.name}
                  </button>
                ))}
              </div>
            </section>
          ))}
        </div>
      </aside>
    </div>
  </div>
</section>

<script src="../scripts/travel-map.ts"></script>

<style>
  .travel-map {
    border-block: 1px solid var(--border-default);
    background: var(--surface-void);
  }

  .travel-map__heading {
    grid-template-columns: minmax(0, 1fr) minmax(280px, 0.7fr);
    align-items: end;
  }

  .travel-map__heading .eyebrow,
  .travel-map__heading h2 {
    grid-column: 1;
  }

  .travel-map__intro {
    grid-column: 2;
    grid-row: 1 / span 2;
    display: grid;
    gap: var(--space-5);
  }

  .travel-map__workspace {
    display: grid;
    grid-template-columns: minmax(0, 3fr) minmax(320px, 1fr);
    overflow: hidden;
  }

  .travel-map__stage {
    position: relative;
    min-width: 0;
    min-height: 560px;
    display: grid;
    grid-template-rows: minmax(0, 1fr) auto;
    border-right: 1px solid var(--border-default);
    background: var(--surface-primary);
    isolation: isolate;
  }

  .travel-map__ambient {
    position: absolute;
    inset: 0;
    z-index: -1;
    opacity: 0.52;
    pointer-events: none;
  }

  .travel-map__ambient :global(picture),
  .travel-map__ambient :global(img) {
    width: 100%;
    height: 100%;
  }

  .travel-map__ambient :global(img) {
    object-fit: cover;
  }

  .travel-map__visual {
    position: relative;
    width: calc(100% - (var(--space-16) * 2));
    max-width: 1000px;
    aspect-ratio: 1000 / 460;
    align-self: center;
    justify-self: center;
  }

  .travel-map__visual svg,
  .travel-map__markers {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
  }

  .travel-map__visual path {
    fill: var(--surface-secondary);
    stroke: var(--border-strong);
    stroke-width: 2;
    vector-effect: non-scaling-stroke;
  }

  .travel-map__marker {
    position: absolute;
    left: var(--marker-x);
    top: var(--marker-y);
    width: 12px;
    height: 12px;
    transform: translate(-50%, -50%);
  }

  .travel-map__marker-ring,
  .travel-map__marker-dot {
    position: absolute;
    inset: 50% auto auto 50%;
    border-radius: var(--radius-circle);
    transform: translate(-50%, -50%);
  }

  .travel-map__marker-ring {
    width: 28px;
    height: 28px;
    border: 1px solid var(--border-strong);
    opacity: 0.72;
    transition: border-color 240ms ease-in-out, opacity 240ms ease-in-out, transform 240ms var(--ease-standard);
  }

  .travel-map__marker-dot {
    width: var(--space-2);
    height: var(--space-2);
    background: var(--text-tertiary);
    transition: background-color 240ms ease-in-out, transform 240ms var(--ease-standard);
  }

  .travel-map__marker-label {
    position: absolute;
    left: var(--label-x);
    top: var(--label-y);
    width: max-content;
    max-width: 120px;
    padding: var(--space-2) var(--space-3);
    border: 1px solid var(--border-default);
    border-radius: var(--radius-control);
    background: var(--surface-primary);
    color: var(--text-primary);
    font-family: var(--font-technical);
    font-size: var(--type-caption);
    line-height: 1;
    opacity: 0;
    transform: translate(-50%, -100%) translateY(var(--space-2));
    transition: opacity 240ms ease-in-out, transform 240ms var(--ease-standard);
    white-space: nowrap;
  }

  .travel-map__marker[data-active="true"] .travel-map__marker-ring {
    border-color: var(--accent-soft);
    opacity: 1;
    transform: translate(-50%, -50%) scale(1.24);
  }

  .travel-map__marker[data-active="true"] .travel-map__marker-dot {
    background: var(--accent-primary);
    transform: translate(-50%, -50%) scale(1.25);
  }

  .travel-map__marker[data-active="true"] .travel-map__marker-label {
    opacity: 1;
    transform: translate(-50%, -100%);
  }

  .travel-map__readout {
    min-height: 76px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-6);
    margin: 0;
    padding: var(--space-4) var(--space-8);
    border-top: 1px solid var(--border-default);
    background: var(--overlay-soft);
  }

  .travel-map__readout span {
    color: var(--text-tertiary);
    font-size: var(--type-micro);
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .travel-map__readout strong {
    font-size: var(--type-h3);
    font-weight: 520;
  }

  .travel-map__index {
    display: grid;
    align-content: start;
    gap: var(--space-8);
    padding: var(--space-8);
    background: var(--surface-secondary);
  }

  .travel-map__index-head {
    display: grid;
    gap: var(--space-3);
    padding-bottom: var(--space-6);
    border-bottom: 1px solid var(--border-default);
  }

  .travel-map__index-head > p:first-child,
  .travel-map__region h3 {
    color: var(--text-tertiary);
    font-size: var(--type-micro);
    letter-spacing: 0.08em;
  }

  .travel-map__index-head > p:last-child {
    color: var(--text-secondary);
    font-size: var(--type-body-sm);
  }

  .travel-map__regions,
  .travel-map__region {
    display: grid;
    gap: var(--space-4);
  }

  .travel-map__regions {
    gap: var(--space-6);
  }

  .travel-map__places {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
  }

  .travel-map__place {
    min-height: 44px;
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    padding: var(--space-2) var(--space-3);
    border: 1px solid var(--border-default);
    border-radius: var(--radius-control);
    background: var(--surface-primary);
    color: var(--text-secondary);
    cursor: pointer;
    font-size: var(--type-body-sm);
    transition: background-color 240ms ease-in-out, border-color 240ms ease-in-out, color 240ms ease-in-out, transform 120ms ease-out;
  }

  .travel-map__place > span {
    width: var(--space-2);
    height: var(--space-2);
    border-radius: var(--radius-circle);
    background: var(--text-tertiary);
    transition: background-color 240ms ease-in-out, transform 240ms var(--ease-standard);
  }

  .travel-map__place:hover,
  .travel-map__place:focus-visible,
  .travel-map__place[aria-pressed="true"] {
    border-color: var(--accent-primary);
    background: var(--surface-elevated);
    color: var(--text-primary);
  }

  .travel-map__place[aria-pressed="true"] > span {
    background: var(--accent-primary);
    transform: scale(1.25);
  }

  .travel-map__place:active {
    transform: translateY(2px);
  }

  @media (max-width: 1023px) {
    .travel-map__workspace {
      grid-template-columns: 1fr;
    }

    .travel-map__stage {
      min-height: 440px;
      border-right: 0;
      border-bottom: 1px solid var(--border-default);
    }

    .travel-map__index {
      grid-template-columns: minmax(220px, 0.45fr) minmax(0, 1fr);
    }

    .travel-map__regions {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 767px) {
    .travel-map__heading {
      grid-template-columns: 1fr;
    }

    .travel-map__intro {
      grid-column: 1;
      grid-row: auto;
    }

    .travel-map__stage {
      min-height: 0;
    }

    .travel-map__visual {
      width: calc(100% - (var(--space-4) * 2));
      margin-block: var(--space-6);
    }

    .travel-map__marker-ring {
      width: var(--space-5);
      height: var(--space-5);
    }

    .travel-map__marker-label {
      max-width: 92px;
      padding: var(--space-2);
      font-size: var(--type-micro);
    }

    .travel-map__readout {
      min-height: 68px;
      padding-inline: var(--space-4);
    }

    .travel-map__index {
      grid-template-columns: 1fr;
      padding: var(--space-6) var(--space-4);
    }

    .travel-map__regions {
      grid-template-columns: 1fr;
    }
  }
</style>
